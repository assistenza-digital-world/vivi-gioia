# ViviGioia — configurazione Apache (Cloudways)

# IMPORTANTE: dai priorità a index.html sul default index.php di Cloudways
DirectoryIndex index.html index.htm index.php

# Charset di default
AddDefaultCharset UTF-8

# ----- Tipi MIME corretti -----
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/svg+xml .svg
  AddType font/woff2 .woff2
  AddType application/manifest+json .webmanifest
  AddType video/mp4 .mp4
</IfModule>

# ----- Compressione -----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE application/xml application/manifest+json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ----- Cache del browser -----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  # asset statici versionabili: cache lunga
  <FilesMatch "\.(webp|jpg|jpeg|png|svg|woff2|mp4|css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML sempre fresco
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Sicurezza di base
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ----- Pagina 404 -----
ErrorDocument 404 /index.html

# ----- Forza HTTPS (attiva dopo aver configurato il certificato su Cloudways) -----
